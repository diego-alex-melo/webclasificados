/.ralph/

# Deep research artifacts (per-investigation)
/.research/

# Environment
.env
.env.local
.env.*.local

# Dependencies
node_modules/

# Next.js
.next/

# Database
prisma/*.db

# Coverage
coverage/
.env.local
src/generated/

.vercel
.env*.local
